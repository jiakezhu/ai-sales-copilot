+function loadAssistantStateTestApi(card, timers, options = {}) {
+  let currentCard = card;
+  const sandbox = {
+    console,
+    document: {
+      addEventListener() {},
+      querySelector(selector) {
+        if (selector === "#copilotCard") return currentCard;
