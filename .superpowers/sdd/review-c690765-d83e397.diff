+.qq-penguin--brand { width: 46px; height: 46px; border-radius: 12px; }
+[data-theme="dark"] {
+  --bg: #0d1119; --surface: #151b25; --surface-2: #1b2330; --surface-3: #242d3c;
+  --ink: #eef2f8; --ink-2: #b4bdcc; --muted: #7e899d; --line: #252e3d; --line-strong: #354156;
+  --blue: #6a9cff; --blue-strong: #8db2ff; --blue-soft: rgba(75,126,235,.16); --violet-soft: rgba(116,86,215,.18);
+  --green-soft: rgba(20,133,102,.18); --red-soft: rgba(212,79,73,.16); --amber-soft: rgba(185,117,22,.16);
+  --shadow-sm: none; --shadow: 0 12px 32px rgba(0,0,0,.18); --shadow-lg: 0 28px 80px rgba(0,0,0,.45);
 }
+html { color-scheme: light; scroll-behavior: smooth; }
+[data-theme="dark"] { color-scheme: dark; }
+body { min-width: 320px; min-height: 100vh; font-family: var(--font); color: var(--ink); background: var(--bg); font-size: 14px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
+button, input, textarea, select { font: inherit; color: inherit; }
+button { cursor: pointer; }
+button:disabled { cursor: not-allowed; opacity: .5; }
+input, textarea, select { outline: none; }
+input::placeholder, textarea::placeholder { color: var(--muted); }
+::selection { color: var(--ink); background: var(--blue-soft); }
+.hidden { display: none !important; }
+.show-mobile { display: none; }
+.app-shell { min-height: 100vh; }
+.app-main { min-height: 100vh; margin-left: var(--side); }
+
+/* Shell */
+.side-nav { position: fixed; inset: 0 auto 0 0; width: var(--side); padding: 20px 16px 16px; display: flex; flex-direction: column; z-index: 50; color: #dbe4f4; background: #101828; border-right: 1px solid rgba(255,255,255,.07); }
+.brand, .mobile-brand { border: 0; background: none; color: inherit; }
+.brand { display: flex; align-items: center; gap: 11px; padding: 4px 7px 24px; text-align: left; }
+.report-brand > span { width: 34px; height: 34px; border-radius: 10px; display: grid; place-items: center; color: #fff; background: linear-gradient(145deg,#6fa1ff,#2864dc); font-size: 16px; font-weight: 800; box-shadow: 0 6px 18px rgba(40,100,220,.3); }
+.brand-copy { display: grid; gap: 1px; }
+.brand-copy b { font-size: 15px; letter-spacing: .02em; }
+.brand-copy small { color: #8492a8; font-size: 10.5px; }
+.primary-nav { display: grid; gap: 5px; }
+.nav-item { position: relative; width: 100%; height: 43px; padding: 0 12px; display: flex; align-items: center; gap: 11px; border: 0; border-radius: 10px; background: transparent; color: #8f9cb0; font-weight: 590; text-align: left; transition: color .18s, background .18s, transform .18s; }
+.nav-item:hover { color: #fff; background: rgba(255,255,255,.055); }
+.nav-item.active { color: #fff; background: rgba(91,143,245,.16); }
+.nav-item.active::before { content:""; position:absolute; left:-16px; width:3px; height:24px; border-radius:0 3px 3px 0; background:#6e9fff; }
+.nav-icon { width: 20px; color: currentColor; font-size: 19px; text-align: center; }
+.nav-item em { margin-left: auto; min-width: 20px; height: 20px; padding: 0 6px; display:grid; place-items:center; border-radius:10px; color:#dce8ff; background:rgba(89,139,235,.22); font-size:10px; font-style:normal; }
+.side-bottom { margin-top: auto; display: grid; gap: 14px; }
+.side-create { height: 42px; display:flex;align-items:center;justify-content:center;gap:7px;border: 1px solid rgba(118,162,246,.3); border-radius: 11px; color: #e8effd; background: rgba(75,125,225,.13); font-weight: 600; transition: .18s; }.side-create svg{width:16px;height:16px}
+.side-create:hover { background: rgba(75,125,225,.25); transform: translateY(-1px); }
+.user-card { padding: 12px 9px 3px; display: flex; gap: 10px; align-items: center; border-top: 1px solid rgba(255,255,255,.07); }
+.user-avatar { width: 30px; height: 30px; display:grid; place-items:center; border-radius:9px; color:#cbd9f3; background:#253249; font-size:12px; font-weight:700; }
+.user-card > span:last-child { display:grid; }
+.user-card b { color:#c6d0df; font-size:12px; font-weight:600; }
+.user-card small { color:#67758b; font-size:10px; }
+.topbar { position: sticky; top: 0; height: 66px; padding: 0 clamp(20px,3vw,42px); display: flex; align-items: center; gap: 20px; z-index: 40; background: color-mix(in srgb, var(--bg) 88%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--line) 80%, transparent); backdrop-filter: blur(18px); }
+.mobile-brand { display:none; font-size:14px; font-weight:700; align-items:center; gap:8px; }
+.global-search { position: relative; width: min(460px,45vw); }
+.global-search input { width:100%; height:38px; padding:0 50px 0 36px; border:1px solid var(--line); border-radius:10px; background:var(--surface); box-shadow:var(--shadow-sm); transition:.18s; }
+.global-search input:focus { border-color:color-mix(in srgb,var(--blue) 48%,var(--line)); box-shadow:0 0 0 3px var(--blue-soft); }
+.search-symbol { position:absolute; top:11px; left:12px; color:var(--muted); line-height:1; }
+.global-search kbd { position:absolute; top:9px; right:9px; padding:2px 6px; border:1px solid var(--line); border-radius:5px; color:var(--muted); background:var(--surface-2); font:10px var(--font); }
+.top-actions { margin-left:auto; display:flex; align-items:center; gap:8px; }
+.icon-button, .secondary-button, .primary-button, .soft-button, .text-button, .voice-button, .attach-button, .report-mini, .arrow-button { border:0; background:none; }
+.icon-button { width:36px; height:36px; display:grid; place-items:center; border:1px solid var(--line); border-radius:10px; color:var(--ink-2); background:var(--surface); font-size:18px; transition:.18s; }
+.icon-button:hover { border-color:var(--line-strong); background:var(--surface-2); }
+.primary-button, .secondary-button, .soft-button { height:38px; padding:0 15px; display:inline-flex; align-items:center; justify-content:center; gap:7px; border-radius:10px; font-weight:650; white-space:nowrap; transition:transform .16s, box-shadow .16s, background .16s; }
+.nav-icon svg{width:18px;height:18px}.search-symbol svg{width:16px;height:16px}.icon-button svg,.primary-button svg,.secondary-button svg,.soft-button svg,.text-button svg,.voice-button svg,.attach-button svg,.mobile-capture svg{width:16px;height:16px;flex:none}.privacy-pill{display:inline-flex;align-items:center;gap:5px}.privacy-pill svg{width:13px;height:13px}.copilot-orb svg{width:18px;height:18px}.report-button svg{width:15px;height:15px}.timeline-dot svg,.timeline-marker svg{width:13px;height:13px}.timeline-aside h3{display:flex;align-items:center;gap:7px}.timeline-aside h3 svg{width:16px;height:16px;color:var(--blue)}
+.primary-button { color:#fff; background:var(--blue); box-shadow:0 5px 14px rgba(40,100,220,.18); }
+.primary-button:hover { background:var(--blue-strong); transform:translateY(-1px); box-shadow:0 8px 18px rgba(40,100,220,.23); }
+.secondary-button { color:var(--ink-2); background:var(--surface); border:1px solid var(--line); }
+.secondary-button:hover { color:var(--ink); border-color:var(--line-strong); background:var(--surface-2); }
+.soft-button { color:var(--blue); background:var(--blue-soft); }
+.soft-button:hover { background:color-mix(in srgb,var(--blue-soft) 78%,var(--blue)); }
+.soft-button.full { width:100%; }
+.text-button { color:var(--blue); font-size:12.5px; font-weight:620; }
+.text-button:hover { color:var(--blue-strong); }
+.spark { font-size:14px; }
+.mobile-nav, .mobile-capture { display:none; }
+
+/* Page foundations */
+.page-root { outline:0; }
+.page { width:min(1280px,100%); margin:0 auto; padding:38px clamp(24px,4vw,54px) 70px; animation:pageIn .32s cubic-bezier(.2,.7,.2,1); }
+@keyframes pageIn { from{opacity:0;transform:translateY(7px)} to{opacity:1;transform:none} }
+h1 { font-size:clamp(27px,3vw,36px); line-height:1.15; letter-spacing:-.035em; }
+h2 { font-size:17px; line-height:1.3; letter-spacing:-.015em; }
+h3 { font-size:14px; }
+.eyebrow { margin-bottom:6px; color:var(--blue); font-size:10.5px; font-weight:760; letter-spacing:.13em; }
+.welcome-row, .page-heading { display:flex; justify-content:space-between; align-items:flex-end; gap:24px; margin-bottom:25px; }
+.welcome-row > div > p:last-child, .page-heading > div > p:last-child { margin-top:8px; color:var(--muted); font-size:13.5px; }
+.panel { padding:20px; border:1px solid var(--line); border-radius:var(--radius-lg); background:var(--surface); box-shadow:var(--shadow-sm); }
+.section-heading { display:flex; justify-content:space-between; align-items:flex-start; gap:14px; margin-bottom:17px; }
+.section-heading > span { color:var(--muted); font-size:12px; }
+.muted { color:var(--muted); }
+.empty-state { min-height:120px; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; color:var(--muted); }
+.empty-state > span { width:26px;height:26px;margin-bottom:8px;display:grid;place-items:center;border-radius:50%;background:var(--surface-2);font-size:20px; }
+.empty-state b { color:var(--ink-2); font-size:13px; }
+.empty-state p { margin-top:4px; font-size:11.5px; }
+
+/* Today & copilot */
+.copilot-card { position:relative; padding:24px; overflow:hidden; border:1px solid color-mix(in srgb,var(--blue) 24%,var(--line)); border-radius:22px; background:linear-gradient(135deg,var(--surface) 58%,color-mix(in srgb,var(--blue-soft) 55%,var(--surface))); box-shadow:0 14px 42px rgba(30,65,130,.08); }
+.copilot-card::after { content:""; position:absolute; width:190px;height:190px;right:-85px;top:-95px;border-radius:50%;background:radial-gradient(circle,color-mix(in srgb,var(--blue) 13%,transparent),transparent 70%);pointer-events:none; }
+.copilot-heading { display:flex; align-items:center; gap:12px; margin-bottom:17px; }
+.copilot-heading h2 { font-size:18px; }
+.copilot-heading p { margin-top:2px; color:var(--muted); font-size:12.5px; }
+.copilot-orb { width:38px;height:38px;display:grid;place-items:center;border-radius:12px;color:#fff;background:linear-gradient(145deg,#725ce0,#2864dc);box-shadow:0 8px 22px rgba(67,88,195,.23);font-size:17px; }
+.privacy-pill { margin-left:auto;padding:5px 9px;border:1px solid color-mix(in srgb,var(--green) 18%,var(--line));border-radius:999px;color:var(--green);background:var(--green-soft);font-size:10.5px;font-weight:650; }
+.copilot-compose { position:relative;border:1px solid var(--line);border-radius:15px;background:var(--surface);box-shadow:var(--shadow-sm);transition:.2s; }
+.copilot-compose:focus-within { border-color:color-mix(in srgb,var(--blue) 50%,var(--line));box-shadow:0 0 0 4px var(--blue-soft); }
+.copilot-compose textarea { width:100%;min-height:84px;padding:14px 16px 7px;resize:none;border:0;background:transparent;color:var(--ink);line-height:1.65; }
+.compose-actions { min-height:47px;padding:7px 8px 8px 12px;display:flex;align-items:center;gap:8px; }
+.attach-button,.voice-button { height:31px;padding:0 10px;display:inline-flex;align-items:center;gap:5px;border-radius:8px;color:var(--ink-2);background:var(--surface-2);font-size:11.5px;font-weight:600; }
+.attach-button:hover,.voice-button:hover { color:var(--ink);background:var(--surface-3); }
+.voice-button.recording { color:var(--red);background:var(--red-soft);animation:pulse 1s infinite; }
+@keyframes pulse { 50%{opacity:.62} }
+.compose-hint { margin-left:3px;color:var(--muted);font-size:10.5px; }
+.compose-actions .primary-button { margin-left:auto;height:34px; }
+.ai-review { margin-top:16px;padding:18px;border:1px solid color-mix(in srgb,var(--blue) 22%,var(--line));border-radius:15px;background:var(--surface);animation:reviewIn .3s ease; }
+@keyframes reviewIn { from{opacity:0;transform:translateY(-6px)} }
+.review-head { display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:14px; }
+.review-kicker { color:var(--green);font-size:10.5px;font-weight:700; }
+.review-head h3 { margin-top:3px;font-size:15px; }
+.review-head label { display:flex;align-items:center;gap:8px;color:var(--muted);font-size:11px; }
+.review-head select { height:33px;padding:0 28px 0 10px;border:1px solid var(--line);border-radius:8px;background:var(--surface-2); }
+.review-head .modern-select{min-width:175px}.review-head .modern-select>svg{top:9px}
+.review-items { display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px; }
+.review-item { position:relative;min-height:66px;padding:11px 12px;display:flex;gap:10px;border:1px solid var(--line);border-radius:11px;background:var(--bg);cursor:pointer; }
+.review-item.main-review { grid-column:1/-1; }
+.review-item input { position:absolute;opacity:0; }
+.review-check { flex:none;width:17px;height:17px;margin-top:2px;display:grid;place-items:center;border:1px solid var(--line-strong);border-radius:5px;background:var(--surface); }
+.review-item input:checked + .review-check { border-color:var(--blue);background:var(--blue); }
+.review-item input:checked + .review-check::after { content:"✓";color:#fff;font-size:10px;font-weight:800; }
+.review-item div { min-width:0;display:grid;gap:3px; }
+.review-item small { color:var(--muted);font-size:10.5px; }
+.review-item b { font-size:12px;font-weight:590;line-height:1.55; }
+.review-item p { color:var(--ink-2);font-size:11px; }
+.review-actions { margin-top:14px;display:flex;align-items:center;justify-content:flex-end;gap:12px; }
+.review-actions > span { margin-right:auto;color:var(--muted);font-size:10.5px; }
