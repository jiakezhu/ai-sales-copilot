{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sales-buddy.local/schemas/cloud-lead-list.v1.schema.json",
  "title": "Cloud lead list import bundle",
  "description": "WorkBuddy 为 CRM 生成的云计算获客候选清单。V1 不按客户类型自动剔除；仅允许导入公开事实，销售行为和内部客户情报不得由此文件生成。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "campaign",
    "summary",
    "leads"
  ],
  "properties": {
    "schema_version": {
      "const": "cloud-lead-list.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "campaign": {
      "$ref": "#/$defs/campaign"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "evidence_file": {
      "type": "string",
      "pattern": "^[^\\/:*?\"<>|]+\\.json$"
    },
    "leads": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/lead"
      }
    }
  },
  "$defs": {
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaign_id", "campaign_name", "product_offer"],
      "properties": {
        "campaign_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "campaign_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "product_offer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "strategy_file": {
          "type": "string",
          "pattern": "^[^\\/:*?\"<>|]+\\.json$"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "executive_summary", "data_quality", "lead_counts"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "executive_summary": {
          "type": "string",
          "maxLength": 4000
        },
        "data_quality": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "lead_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["A", "B", "C", "manual_review"],
          "properties": {
            "A": { "type": "integer", "minimum": 0 },
            "B": { "type": "integer", "minimum": 0 },
            "C": { "type": "integer", "minimum": 0 },
            "manual_review": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "lead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "research_readiness",
        "score",
        "signals",
        "research",
        "proposed_crm_import",
        "evidence",
        "unknowns"
      ],
      "properties": {
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "research_readiness": {
          "$ref": "#/$defs/researchReadiness"
        },
        "score": {
          "$ref": "#/$defs/score"
        },
        "signals": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/signal"
          }
        },
        "research": {
          "$ref": "#/$defs/research"
        },
        "proposed_crm_import": {
          "$ref": "#/$defs/crmImport"
        },
        "evidence": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "unknowns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["company_name"],
      "properties": {
        "company_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "unified_social_credit_code": {
          "type": "string",
          "maxLength": 64
        },
        "website": {
          "type": "string",
          "format": "uri",
          "maxLength": 2000
        },
        "headquarters": {
          "type": "string",
          "maxLength": 300
        },
        "parent_group": {
          "type": "string",
          "maxLength": 300
        },
        "external_company_ids": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "researchReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready_for_review", "manual_review"]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_relevance",
        "technical_scenario_relevance",
        "purchase_timing",
        "evidence_quality",
        "total",
        "tier",
        "reasons"
      ],
      "properties": {
        "business_relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 40
        },
        "technical_scenario_relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 25
        },
        "purchase_timing": {
          "type": "number",
          "minimum": 0,
          "maximum": 25
        },
        "evidence_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "total": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "tier": {
          "type": "string",
          "enum": ["A", "B", "C", "manual_review"]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "strength", "statement", "evidence_ids"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cloud_native_hiring",
            "ai_compute_hiring_or_launch",
            "new_product_or_expansion",
            "funding_or_team_growth",
            "public_tender",
            "industry_match",
            "other"
          ]
        },
        "strength": {
          "type": "string",
          "enum": ["strong", "medium", "weak"]
        },
        "observed_at": {
          "type": "string",
          "format": "date"
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "research": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_facts",
        "cloud_scenarios",
        "demand_hypotheses",
        "discovery_questions"
      ],
      "properties": {
        "public_facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "cloud_scenarios": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cloudScenario"
          }
        },
        "demand_hypotheses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hypothesis"
          }
        },
        "discovery_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "evidence_ids"],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "cloudScenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "hypothesis", "confidence", "evidence_ids"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ai_compute",
            "cloud_native",
            "elastic_traffic",
            "data_platform",
            "global_deployment",
            "security_resilience",
            "cost_optimization",
            "unknown"
          ]
        },
        "hypothesis": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "confidence", "evidence_ids"],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "crmImport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "customer"],
      "properties": {
        "operation": {
          "const": "create_lead"
        },
        "customer": {
          "$ref": "#/$defs/crmCustomer"
        },
        "contacts": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/contact"
          }
        }
      }
    },
    "crmCustomer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "stage", "grade", "fields"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "stage": {
          "const": "lead"
        },
        "grade": {
          "type": "string",
          "enum": ["A", "B", "C"]
        },
        "fields": {
          "$ref": "#/$defs/publicCrmFields"
        }
      }
    },
    "publicCrmFields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "industry": { "$ref": "#/$defs/factText" },
        "founded": { "$ref": "#/$defs/factText" },
        "staff": { "$ref": "#/$defs/factText" },
        "funding": { "$ref": "#/$defs/factText" },
        "product": { "$ref": "#/$defs/factText" },
        "dau": { "$ref": "#/$defs/factText" },
        "revenue": { "$ref": "#/$defs/factText" }
      }
    },
    "factText": {
      "type": "string",
      "maxLength": 2000
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "level", "evidence_ids"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "role": {
          "type": "string",
          "maxLength": 200
        },
        "level": {
          "type": "integer",
          "enum": [1, 2, 3]
        },
        "phone": {
          "type": "string",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "format": "email",
          "maxLength": 320
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_type",
        "provider",
        "retrieved_at",
        "claim",
        "source_reference"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "source_type": {
          "type": "string",
          "enum": [
            "enterprise_registry",
            "company_website",
            "official_news",
            "public_recruitment",
            "public_tender",
            "authorized_financial_database",
            "other"
          ]
        },
        "provider": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "source_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 2000
        },
        "published_at": {
          "type": "string",
          "format": "date"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "excerpt": {
          "type": "string",
          "maxLength": 4000
        }
      }
    }
  }
}
