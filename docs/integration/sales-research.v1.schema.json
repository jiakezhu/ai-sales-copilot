{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sales-buddy.local/schemas/sales-research.v1.schema.json",
  "title": "Sales Buddy research import bundle",
  "description": "WorkBuddy 获客清单和单客户调研产物的机器可读导入契约。CRM 只应在预览、去重和人工确认后应用其中的 proposed_crm_updates。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "artifact_type",
    "summary",
    "companies"
  ],
  "properties": {
    "schema_version": {
      "const": "sales-research.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "同一导入包内 JSON、Markdown 与 manifest 共用的稳定运行标识。"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["lead_list", "account_research"]
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_request": { "type": "string" },
        "icp": { "type": "object" },
        "target_company": { "type": "string" }
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "report_file": {
      "type": "string",
      "pattern": "^[^\\\\/:*?\"<>|]+\\.md$",
      "description": "同一导入包中的人类可读 Markdown 报告文件名，例如 account-research.md。"
    },
    "companies": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/company" }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "executive_summary", "data_quality"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "executive_summary": { "type": "string", "maxLength": 4000 },
        "data_quality": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "match",
        "customer",
        "research",
        "proposed_crm_updates",
        "evidence",
        "conflicts",
        "unknowns"
      ],
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["create_lead", "update_customer", "attach_research_only"]
        },
        "match": { "$ref": "#/$defs/match" },
        "customer": { "$ref": "#/$defs/customer" },
        "contacts": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/contact" }
        },
        "research": { "$ref": "#/$defs/research" },
        "proposed_crm_updates": { "$ref": "#/$defs/crmUpdates" },
        "evidence": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "conflicts": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        },
        "unknowns": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1000 }
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crm_customer_id": { "type": "string", "maxLength": 200 },
        "unified_social_credit_code": { "type": "string", "maxLength": 64 },
        "external_company_ids": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "stage", "grade", "fields"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "stage": {
          "type": "string",
          "enum": ["lead", "contact", "meeting", "proposal", "won", "lost"]
        },
        "grade": { "type": "string", "enum": ["S", "A", "B", "C"] },
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "industry": { "$ref": "#/$defs/factText" },
            "founded": { "$ref": "#/$defs/factText" },
            "staff": { "$ref": "#/$defs/factText" },
            "funding": { "$ref": "#/$defs/factText" },
            "product": { "$ref": "#/$defs/factText" },
            "dau": { "$ref": "#/$defs/factText" },
            "revenue": { "$ref": "#/$defs/factText" },
            "cloudStatus": { "$ref": "#/$defs/factText" },
            "billNote": { "$ref": "#/$defs/factText" },
            "relation": { "$ref": "#/$defs/factText" }
          }
        }
      }
    },
    "factText": {
      "type": "string",
      "maxLength": 2000,
      "description": "CRM 情报字段的文本值；为空时表示未知，不能用推测补全。"
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "level", "note", "evidence_ids"],
      "properties": {
        "name": { "type": "string", "maxLength": 200 },
        "role": { "type": "string", "maxLength": 200 },
        "level": { "type": "integer", "enum": [1, 2, 3] },
        "pid": { "type": "string", "maxLength": 200 },
        "phone": { "type": "string", "maxLength": 100 },
        "wechat": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "format": "email", "maxLength": 320 },
        "note": { "type": "string", "maxLength": 2000 },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "research": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company_profile",
        "business_signals",
        "financial_signals",
        "risk_signals",
        "competitors",
        "pain_points",
        "sales_hypotheses",
        "recommended_actions"
      ],
      "properties": {
        "company_profile": { "$ref": "#/$defs/findingList" },
        "business_signals": { "$ref": "#/$defs/findingList" },
        "financial_signals": { "$ref": "#/$defs/findingList" },
        "risk_signals": { "$ref": "#/$defs/findingList" },
        "competitors": { "$ref": "#/$defs/findingList" },
        "pain_points": { "$ref": "#/$defs/findingList" },
        "sales_hypotheses": {
          "type": "array",
          "items": { "$ref": "#/$defs/hypothesis" }
        },
        "recommended_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "findingList": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "evidence_ids"],
      "properties": {
        "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "confidence", "evidence_ids"],
      "properties": {
        "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "priority", "reason", "evidence_ids"],
      "properties": {
        "action": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "due_date": { "type": "string", "pattern": "^$|^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "maxLength": 2000 },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "crmUpdates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields", "notes", "pain_points", "solutions"],
      "properties": {
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "industry": { "$ref": "#/$defs/factText" },
            "founded": { "$ref": "#/$defs/factText" },
            "staff": { "$ref": "#/$defs/factText" },
            "funding": { "$ref": "#/$defs/factText" },
            "product": { "$ref": "#/$defs/factText" },
            "dau": { "$ref": "#/$defs/factText" },
            "revenue": { "$ref": "#/$defs/factText" },
            "cloudStatus": { "$ref": "#/$defs/factText" },
            "billNote": { "$ref": "#/$defs/factText" },
            "relation": { "$ref": "#/$defs/factText" }
          }
        },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/note" }
        },
        "pain_points": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 2000 }
        },
        "solutions": {
          "type": "array",
          "items": { "$ref": "#/$defs/solution" }
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "method", "content", "next", "nextDate", "taskDone"],
      "properties": {
        "date": { "type": "string", "minLength": 1, "maxLength": 100 },
        "method": { "type": "string", "enum": ["phone", "wechat", "email", "visit", "meeting", "other"] },
        "contact": { "type": "string", "maxLength": 200 },
        "place": { "type": "string", "maxLength": 300 },
        "content": { "type": "string", "minLength": 1, "maxLength": 5000 },
        "next": { "type": "string", "maxLength": 2000 },
        "nextDate": { "type": "string", "pattern": "^$|^\\d{4}-\\d{2}-\\d{2}$" },
        "taskDone": { "type": "boolean" }
      }
    },
    "solution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "reason"],
      "properties": {
        "product": { "type": "string", "minLength": 1, "maxLength": 500 },
        "reason": { "type": "string", "maxLength": 2000 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "retrieved_at", "claim", "fact_or_inference"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 100 },
        "provider": { "type": "string", "minLength": 1, "maxLength": 200 },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri", "maxLength": 2000 },
        "claim": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "excerpt": { "type": "string", "maxLength": 4000 },
        "fact_or_inference": { "type": "string", "enum": ["fact", "inference"] }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "description", "evidence_ids"],
      "properties": {
        "field": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    }
  }
}
